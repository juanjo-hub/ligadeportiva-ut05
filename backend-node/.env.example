# Cadena de conexión a MongoDB Atlas
# Sustituye <db_password> por la contraseña real del usuario de la base de datos
MONGODB_URI=mongodb+srv://<usuario>:<db_password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=LigaDeportiva

# Puerto en el que escucha el servidor (Render lo asigna automáticamente con $PORT)
PORT=3000
